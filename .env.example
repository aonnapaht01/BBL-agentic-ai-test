# =============================================================================
# BBL AI Engineer Programming Test - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Provider Priority ---------------------------------------------------
# The system selects the LLM backend automatically based on the presence of API keys:
#   1. GROQ_API_KEY    → Groq (Priority 1: Fast & free local testing)
#   2. GOOGLE_API_KEY  → Google Gemini (Priority 2: Free local testing)
#   3. AZURE_OPENAI_*  → Azure OpenAI (Priority 3: Enterprise / BBL production)
#   4. OPENAI_API_KEY  → Standard OpenAI (Priority 4: Default fallback)

# --- Groq (Priority 1) ------------------------------------------------------
# GROQ_API_KEY=your-groq-api-key-here

# --- Google Gemini (Priority 2) ---------------------------------------------
# GOOGLE_API_KEY=your-google-api-key-here

# --- Azure OpenAI (Priority 3) ----------------------------------------------
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01

# --- OpenAI (Priority 4) ----------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# --- Model Configuration ----------------------------------------------------
LLM_MODEL=gpt-5-mini
LLM_TEMPERATURE=0.0

# --- Knowledge Base ----------------------------------------------------------
KNOWLEDGE_BASE_PATH=./data/knowledge_base.txt
